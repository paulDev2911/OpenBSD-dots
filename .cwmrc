borderwidth 2
color border-active   "#ffffff"
color border-inactive "#333333"
color background      "black"

gap 20 0 0 0

snapdist 8

bind-key 4-Return    xterm
bind-key 4-p         dmenu_run

bind-key 4-q         window-delete
bind-key 4-f         window-fullscreen
bind-key 4-m         window-maximize
bind-key 4-Tab       window-cycle
bind-key 4S-Tab      window-rcycle

bind-key 4-Left      window-snap-left
bind-key 4-Right     window-snap-right
bind-key 4-Up        window-snap-up
bind-key 4-Down      window-snap-down

bind-key 4-t         window-vtile

bind-key 4-h         window-hide

bind-key 4-1         group-only-1
bind-key 4-2         group-only-2
bind-key 4-3         group-only-3
bind-key 4S-1        window-movetogroup-1
bind-key 4S-2        window-movetogroup-2
bind-key 4S-3        window-movetogroup-3

command xterm        xterm
command dmenu        dmenu_run
command firefox      firefox